{
  "name": "rta-vscode",
  "displayName": "RTA",
  "description": "AI-assisted coding with the RTA agent — chat, edit, search, and more.",
  "version": "0.1.0",
  "publisher": "rta",
  "license": "MIT",
  "private": true,
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Chat",
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "cursor",
    "copilot",
    "agent"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rta.chat.toggle",
        "title": "RTA: Toggle Chat"
      },
      {
        "command": "rta.chat.addSelection",
        "title": "RTA: Add Selection to Chat"
      },
      {
        "command": "rta.chat.addFile",
        "title": "RTA: Add File to Chat"
      },
      {
        "command": "rta.inline.explain",
        "title": "RTA: Explain Selection"
      },
      {
        "command": "rta.inline.edit",
        "title": "RTA: Edit Selection with AI"
      },
      {
        "command": "rta.inline.fix",
        "title": "RTA: Fix Diagnostics"
      },
      {
        "command": "rta.agent.status",
        "title": "RTA: Show Agent Status"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rta-sidebar",
          "title": "RTA",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "rta-sidebar": [
        {
          "type": "webview",
          "id": "rta.chat",
          "name": "Chat"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "rta.chat.addSelection",
          "group": "rta@1"
        },
        {
          "command": "rta.inline.explain",
          "group": "rta@2"
        },
        {
          "command": "rta.inline.edit",
          "group": "rta@3"
        }
      ],
      "explorer/context": [
        {
          "command": "rta.chat.addFile",
          "group": "rta@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rta.chat.toggle",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorFocus"
      },
      {
        "command": "rta.chat.addSelection",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorHasSelection"
      }
    ]
  },
  "icon": "icon.png",
  "devDependencies": {
    "@types/vscode": "^1.96.0"
  }
}
